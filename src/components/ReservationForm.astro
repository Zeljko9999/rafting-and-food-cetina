---
const packageOptions = [
  "Rafting adventure",
  "Rafting + food package",
  "Food experience only",
  "Private group inquiry"
];
---

<section class="section section--alt">
  <div class="container split split--wide">
    <div class="panel reservation-panel">
      <p class="eyebrow">Reservation form</p>
      <h2>Send a reservation request from the home page</h2>
      <p>
        This form is prepared for a no-database workflow. It will send the filled data to
        your admin email through a Cloudflare function and an email provider.
      </p>

      <form
        action="/api/reservation"
        method="post"
        class="reservation-form"
        data-reservation-form
      >
        <div class="form-grid">
          <label class="field">
            <span>Preferred date</span>
            <input type="date" name="tripDate" required data-date-input />
          </label>

          <label class="field">
            <span>Guests</span>
            <input
              type="number"
              name="guests"
              min="1"
              max="30"
              step="1"
              value="2"
              required
            />
          </label>

          <label class="field">
            <span>Full name</span>
            <input type="text" name="fullName" placeholder="John Smith" required />
          </label>

          <label class="field">
            <span>Email</span>
            <input type="email" name="email" placeholder="john@example.com" required />
          </label>

          <label class="field">
            <span>Phone</span>
            <input type="tel" name="phone" placeholder="+385 ..." />
          </label>

          <label class="field">
            <span>Package</span>
            <select name="packageType" required>
              {packageOptions.map((option) => (
                <option value={option}>{option}</option>
              ))}
            </select>
          </label>

          <label class="field field--full">
            <span>Message</span>
            <textarea
              name="message"
              rows="5"
              placeholder="Tell us about your group, preferred time, or any special request."
            ></textarea>
          </label>
        </div>

        <input type="text" name="website" class="field-honeypot" tabindex="-1" autocomplete="off" />

        <div class="form-actions">
          <button type="submit" class="button button--primary" data-submit-button>
            Send reservation
          </button>
          <p class="form-note">
            Placeholder recipient email is set in the function and can be changed later.
          </p>
        </div>

        <p class="form-status" data-form-status role="status" aria-live="polite"></p>
      </form>
    </div>

    <aside class="card card--summary">
      <p class="eyebrow">How it works</p>
      <h3>Simple and lightweight</h3>
      <p>The guest fills the date and basic information.</p>
      <p>The form sends the request to a Cloudflare Pages Function.</p>
      <p>The function sends an automatic email with the filled reservation details.</p>
      <p>No database is required for this setup.</p>
    </aside>
  </div>
</section>

<script is:inline>
  const form = document.querySelector("[data-reservation-form]");
  const status = document.querySelector("[data-form-status]");
  const submitButton = document.querySelector("[data-submit-button]");
  const dateInput = document.querySelector("[data-date-input]");

  if (dateInput instanceof HTMLInputElement) {
    const today = new Date();
    const localDate = new Date(today.getTime() - today.getTimezoneOffset() * 60000)
      .toISOString()
      .slice(0, 10);
    dateInput.min = localDate;
  }

  if (form instanceof HTMLFormElement && status instanceof HTMLElement && submitButton instanceof HTMLButtonElement) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      status.dataset.state = "pending";
      status.textContent = "Sending your reservation request...";
      submitButton.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: {
            Accept: "application/json"
          }
        });

        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.message || "Something went wrong while sending the request.");
        }

        status.dataset.state = "success";
        status.textContent = result.message || "Reservation request sent successfully.";
        form.reset();

        if (dateInput instanceof HTMLInputElement && dateInput.min) {
          dateInput.value = "";
        }
      } catch (error) {
        status.dataset.state = "error";
        status.textContent =
          error instanceof Error
            ? error.message
            : "Unable to send the reservation request right now.";
      } finally {
        submitButton.disabled = false;
      }
    });
  }
</script>
